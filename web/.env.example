# Copy to .env.local (never commit .env.local)

# --- Server & middleware (recommended: no NEXT_PUBLIC_ prefix) ---
# Same values as below; used by Server Components + middleware so they are not
# pulled in as public env unless needed elsewhere.
SUPABASE_URL=https://vmqvhzghfbwcfnxittta.supabase.co
SUPABASE_ANON_KEY=

# --- Browser (required for /teacher login) ---
NEXT_PUBLIC_SUPABASE_URL=https://vmqvhzghfbwcfnxittta.supabase.co
# Legacy JWT anon OR new publishable key (sb_publishable_…)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Server-only (never NEXT_PUBLIC_) ---
GEMINI_API_KEY=
# Default in code is gemini-2.5-flash; override if your project uses another id:
# GEMINI_MODEL=gemini-2.5-flash

# Server-only — required for `npm run create-teacher` script (never expose to client or NEXT_PUBLIC_)
# SUPABASE_SERVICE_ROLE_KEY=
